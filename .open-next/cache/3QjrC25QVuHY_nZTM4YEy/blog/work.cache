d\",\"marginTop\":\"$undefined\",\"marginBottom\":\"$undefined\",\"lineHeight\":\"175%\"},\"children\":\"You can use MDX to write the content of your projects. It helps you write rich and dynamic content with minimal code. Some MDX elements will be automatically transformed to Once UI components to integrate better in the design and add additional functionality.\"}],\"\\n\",[\"$\",\"$L2d\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"custom-components\",\"children\":\"Custom components\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"textAlign\":\"$undefined\",\"textWrap\":\"$undefined\",\"padding\":\"$undefined\",\"paddingLeft\":\"$undefined\",\"paddingRight\":\"$undefined\",\"paddingTop\":\"$undefined\",\"paddingBottom\":\"$undefined\",\"margin\":\"$undefined\",\"marginLeft\":\"$undefined\",\"marginRight\":\"$undefined\",\"marginTop\":\"$undefined\",\"marginBottom\":\"$undefined\",\"lineHeight\":\"175%\"},\"children\":[\"You can use custom components in MDX files, but you need to import them first in the \",[\"$\",\"$L2e\",null,{\"children\":\"src/components/mdx.tsx\"}],\" file.\"]}],\"\\n\",[\"$\",\"$L2f\",null,{\"marginBottom\":\"16\",\"highlight\":\"11-12\",\"codes\":[{\"code\":\"const components = {\\n  p: createParagraph as any,\\n  h1: createHeading(1) as any,\\n  h2: createHeading(2) as any,\\n  h3: createHeading(3) as any,\\n  h4: createHeading(4) as any,\\n  h5: createHeading(5) as any,\\n  h6: createHeading(6) as any,\\n  img: createImage as any,\\n  a: CustomLink as any,\\n  Table,\\n  CodeBlock,\\n};\",\"language\":\"tsx\",\"label\":\"src/components/mdx.tsx\"}]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"textAlign\":\"$undefined\",\"textWrap\":\"$undefined\",\"padding\":\"$undefined\",\"paddingLeft\":\"$undefined\",\"paddingRight\":\"$undefined\",\"pad