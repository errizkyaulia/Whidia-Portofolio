de\":\"---\\ntitle: \\\"Developing a design system for indie creators\\\"\\npublishedAt: \\\"2025-03-17\\\"\\nsummary: \\\"Once UI is a design system that empowers indie creators, small teams, and startups to build web applications.\\\"\\nimages:\\n- \\\"/images/projects/project-01/cover-02.jpg\\\"\\n- \\\"/images/projects/project-01/image-03.jpg\\\"\\nteam:\\n- name: \\\"Lorant One\\\"\\n  role: \\\"Software Engineer\\\"\\n  avatar: \\\"/images/avatar.jpg\\\"\\n  linkedIn: \\\"https://www.linkedin.com/company/once-ui/\\\"\\nlink: \\\"https://once-ui.com/\\\"\\n---\",\"language\":\"tsx\",\"label\":\"src/app/work/projects/project-1.mdx\"}]}],\"\\n\",[\"$\",\"$L2d\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"mdx-syntax\",\"children\":\"MDX syntax\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"textAlign\":\"$undefined\",\"textWrap\":\"$undefined\",\"padding\":\"$undefined\",\"paddingLeft\":\"$undefined\",\"paddingRight\":\"$undefined\",\"paddingTop\":\"$undefined\",\"paddingBottom\":\"$undefined\",\"margin\":\"$undefined\",\"marginLeft\":\"$undefined\",\"marginRight\":\"$undefined\",\"marginTop\":\"$undefined\",\"marginBottom\":\"$undefined\",\"lineHeight\":\"175%\"},\"children\":\"You can use MDX to write the content of your projects. It helps you write rich and dynamic content with minimal code. Some MDX elements will be automatically transformed to Once UI components to integrate better in the design and add additional functionality.\"}],\"\\n\",[\"$\",\"$L2d\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"custom-components\",\"children\":\"Custom components\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"textAlign\":\"$undefined\",\"textWrap\":\"$undefined\",\"padding\":\"$undefined\",\"paddingLeft\":\"$undefined\",\"paddingRight\":\"$undefined\",\"paddingTop\":\"$undefined\",\"paddingBottom\":\"$undefined\",\"margin\":\"$undefined\",\"marginLeft\":\"$undefined\",\"marginRight\":\"$undefined\",\"marginTop\":\"$undefined\",\"marginBottom\":\"$undefined\",\"lineHeight\":\"175%\"},\"children\":[\"You can use custom components in MDX files, but you need to import them first in the \",[\"$\",\"$L2e\",null,{\"children\":\"src/components/mdx.tsx\"}],\" file.\"]}],\"\\n\",[\"$\",\"$L2f\",null,{\"marginBottom\":\"16\",\"highlight\":\"11-12\",\"codes\":[{\"code\":\"const components = {\\n  p: createParagraph as any,\\n  h1: createHeading(1) as any,\\n  h2: createHeading(2) as any,\\n  h3: createHeading(3) as any,\\n  h4: createHeading(4) as any,\\n  h5: createHeading(5) as any,\\n  h6: createHeading(6) as any,\\n  img: createImage as any,\\n  a: CustomLink as any,\\n  Table,\\n  CodeBlock,\\n};\",\"language\":\"tsx\",\"label\":\"src/components/mdx.tsx\"}]}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"textAlign\":\"$undefined\",\"textWrap\":\"$undefined\",\"padding\":\"$undefined\",\"paddingLeft\":\"$undefined\",\"paddingRight\":\"$undefined\",\"paddingTop\":\"$undefined\",\"paddingBottom\":\"$undefined\",\"margin\":\"$undefined\",\"marginLeft\":\"$undefined\",\"marginRight\":\"$undefined\",\"marginTop\":\"$undefined\",\"marginBottom\":\"$undefined\",\"lineHeight\":\"175%\"},\"children\":[\"As you can see, the \",[\"$\",\"$L2e\",null,{\"children\":\"Table\"}],\" and \",[\"$\",\"$L2e\",null,{\"children\":\"CodeBlock\"}],\" components are already imported and available for use. You can add more by simply importing them to this file and passing them to the \",\"$L30\",\" object.\"]}],\"\\n\",\"$L31\",\"\\n\",\"$L32\"]\n30:[\"$\",\"$L2e\",null,{\"children\":\"components\"}]\n31:[\"$\",\"$L2d\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"hot-reload\",\"children\":\"Hot reload\"}]\n32:[\"$\",\"span