elete projects\"}],\"\"]}],[\"$\",\"div\",null,{\"className\":\"display-flex position-relative mb-32 justify-center \",\"style\":{},\"children\":[\"$\",\"div\",null,{\"className\":\"display-flex position-relative g-16 align-center \",\"style\":{},\"children\":[[\"$\",\"$L5\",null,{\"size\":\"s\",\"src\":\"/images/avatarku.jpg\"}],[\"$\",\"span\",null,{\"className\":\"font-label font-default font-m brand-on-background-weak\",\"style\":{},\"children\":\"Whidia Banjarsari\"}]]}]}],\"\",[\"$\",\"article\",null,{\"className\":\"display-flex position-relative flex-column fill-width max-width-s \",\"style\":{},\"children\":[[\"$\",\"$L6\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"manage-projects\",\"children\":\"Manage projects\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":[\"You can create, edit and delete projects by adding, modifying or removing \",[\"$\",\"$L7\",null,{\"children\":\"*.mdx\"}],\" files in the \",[\"$\",\"$L7\",null,{\"children\":\"src/app/work/projects\"}],\" directory.\"]}],\"\\n\",[\"$\",\"$L6\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"frontmatter\",\"children\":\"Frontmatter\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":\"The frontmatter is used to set the project's metadata: title, description, image, and tags. It's used in the project's page and in meta- and open graph tags.\"}],\"\\n\",[\"$\",\"$L8\",null,{\"marginBottom\":\"16\",\"codes\":[{\"code\":\"---\\ntitle: \\\"Developing a design system for indie creators\\\"\\npublishedAt: \\\"2025-03-17\\\"\\nsummary: \\\"Once UI is a design system that empowers indie creators, small teams, and startups to build web applications.\\\"\\nimages:\\n- \\\"/images/projects/project-01/cover-02.jpg\\\"\\n- \\\"/images/projects/project-01/image-03.jpg\\\"\\nteam:\\n- name: \\\"Lorant One\\\"\\n  role: \\\"Software Engineer\\\"\\n  avatar: \\\"/images/avatar.jpg\\\"\\n  linkedIn: \\\"https://www.linkedin.com/company/once-ui/\\\"\\nlink: \\\"https://once-ui.com/\\\"\\n---\",\"language\":\"tsx\",\"label\":\"src/app/work/projects/project-1.mdx\"}]}],\"\\n\",[\"$\",\"$L6\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"mdx-syntax\",\"children\":\"MDX syntax\"}],\"\\n\",[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":\"You can use MDX to write the content of your projects. It helps you write rich and dynamic content with minimal code. Some MDX elements will be automatically transformed to Once UI components to integrate better in the design and add additional functionality.\"}],\"\\n\",\"$L9\",\"\\n\",\"$La\",\"\\n\",\"$Lb\",\"\\n\",\"$Lc\",\"\\n\",\"$Ld\",\"\\n\",\"$Le\"]}],\"$Lf\",\"$L10\",\"$L11\"]}]}],\"$L12\"]}],[\"$L13\"],\"$L14\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"3QjrC25QVuHY_nZTM4YEy\"}\n9:[\"$\",\"$L6\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"custom-components\",\"children\":\"Custom components\"}]\na:[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":[\"You can use custom components in MDX files, but you need to import them first in the \",[\"$\",\"$L7\",null,{\"children\":\"src/components/mdx.tsx\"}],\" file.\"]}]\nb:[\"$\",\"$L8\",null,{\"marginBottom\":\"16\",\"highlight\":\"11-12\",\"codes\":[{\"code\":\"const components = {\\n  p: createParagraph as any,\\n  h1: createHeading(1) as any,\\n  h2: createHeading(2) as any,\\n  h3: createHeading(3) as any,\\n  h4: createHeading(4) as any,\\n  h5: createHeading(5) as any,\\n  h6: createHeading(6) as any,\\n  img: createImage as any,\\n  a: CustomLink as any,\\n  Table,\\n  CodeBlock,\\n};\",\"language\":\"tsx\",\"label\":\"src/components/mdx.tsx\"}]}]\nc:[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":[\"As you can see, the \",[\"$\",\"$L7\",null,{\"children\":\"Table\"}],\" and \",[\"$\",\"$L7\",null,{\"children\":\"CodeBlock\"}],\" components are already imported and available for use. You can add more by simply importing them to this file and passing them to the \",[\"$\",\"$L7\",null,{\"children\":\"components\"}],\" object.\"]}]\nd:[\"$\",\"$L6\",null,{\"marginTop\":\"24\",\"marginBottom\":\"12\",\"as\":\"h2\",\"id\":\"hot-reload\",\"children\":\"Hot reload\"}]\ne:[\"$\",\"span\",null,{\"className\":\"font-body font-default font-m neutral-on-background-medium mt-8 mb-12\",\"style\":{\"lineHeight\":\"175%\"},\"children\":\"Hot reload of MDX files is currently not supported, but we're working on it.\"}]\nf:[\"$\",\"$L15\",null,{\"title\":\"Create,edit and delete projects\",\"url\":\"https://whidiabanjarsari.com/blog/work\"}]\n19:T465,\r\n## About\r\n\r\nMagic Portfolio is a comprehensive, MDX-based, SEO-friendly, responsive portfolio template built with Once UI and Next.js.\r\n\r\n## License\r\n\r\nMagic Portfolio is licensed under the [CC BY-NC 4.0](https://creativecommons.org/licenses/by-nc/4.0/). You can only use it for personal purposes, and you must attribute the original work. The attribution is added in the footer by default, but you can place it in any other, visible part of your site.\r\n\r\nSubscribe to the [Once UI Pro plan](https://once-ui.com/pricing) to extend the license to [Dopler CC](https://once-ui.com/products/magic-portfolio).\r\n\r\n## Quick start\r\n\r\nClone the git repository:\r\n\r\n<CodeBlock compact marginBottom=\"16\" codes={[\r\n  {\r\n    code: \"git clone https://github.com/once-ui-system/magic-portfolio.git\",\r\n    language: \"bash\"\r\n  }\r\n]} />\r\n\r\nInstall the necessary dependencies:\r\n\r\n<CodeBlock compact marginBottom=\"16\" codes={[\r\n  {\r\n    code: \"npm install\",\r\n    language: \"bash\"\r\n  }\r\n]} />\r\n\r\nStart the local development server:\r\n\r\n<CodeBlock compact marginBottom=\"16\" codes={[\r\n  {\r\n    code: \"npm run dev\",\r\n    language: \"bash\"\r\n  }\r\n]} />1a:T4cd,\r\n## Enable or disable pages\r\n\r\nMagic Portfolio's `RouteGuard` component takes care of conditionally rendering pages based on the `routes` object in the `resources/config.js` file.\r\n\r\n<CodeBlock\r\n    marginBottom=\"16\"\r\n    highlight=\"6\"\r\n    codes={[\r\n  {\r\n    code:\r\n`const routes = {\r\n    '/':        true,\r\n    '/about':   true,\r\n    '/work':    true,\r\n    '/blog':    true,\r\n    '/gallery': false,\r\n};`,\r\n    language: \"tsx\",\r\n    label: \"src/app/resources/config.js\"\r\n  }\r\n]} />\r\n\r\nThe code above will ensure that the `/gallery` page is not accessible and is not displayed in the navigation.\r\n\r\n## Add new pages\r\n\r\nWhen creating a new page, it needs to be added to the `routes` object in the `resources/config.js` file.\r\n\r\n<CodeBlock\r\n    marginBottom=\"16\"\r\n    highlight=\"6\"\r\n    codes={[\r\n  {\r\n    code:\r\n`const routes = {\r\n    '/':        true,\r\n    '/about':   true,\r\n    '/work':    true,\r\n    '/blog':    true,\r\n    '/gallery': false,\r\n    '/music': true,\r\n};`,\r\n    language: \"tsx\",\r\n    label: \"src/app/resources/config.js\"\r\n  }\r\n]} />\r\n\r\nThe code above will ensure that the `/music` page is accessible. Users will be able to navigate to it after adding it to the navigation menu in the `components/Header.tsx` file.10:[\"$\",\"div\",null,{\"className\":\"display-flex position-relative mt-40 g-40 flex-column align-center min-width-0 fill-width \",\"style\":{},\"children\":[[\"$\",\"$L16\",null,{\"maxWidth\":\"40\"}],[\"$\",\"h2\",null,{\"className\":\"font-heading font-strong font-xl mb-24\",\"style\":{},\"id\":\"recent-posts\",\"children\":\"Recent posts\"}],[\"$\",\"$L17\",null,{\"s\":{\"columns\":1},\"columns\":\"2\",\"fillWidth\":true,\"marginBottom\":\"40\",\"gap\":\"16\",\"children\":[[\"$\",\"$L18\",\"quick-start\",{\"post\":{\"metadata\":{\"title\":\"Quick start with Magic Portfolio\",\"subtitle\":\"A comprehensive guide to setting up your professional portfolio in minutes\",\"publishedAt\":\"2025-04-23\",\"summary\":\"Magic Portfolio is a comprehensive, MDX-based, SEO-friendly, responsive portfolio template built with Once UI and Next.js.\",\"image\":\"/images/gallery/horizontal-1.jpg\",\"images\":[],\"tag\":\"Magic Portfolio\",\"team\":[],\"link\":\"\"},\"slug\":\"quick-start\",\"content\":\"$19\"},\"thumbnail\":true,\"direction\":\"column\"}],[\"$\",\"$L18\",\"pages\",{\"post\":{\"metadata\":{\"title\":\"Enable or disable pages for your portfolio\",\"subtitle\":\"\",\"publishedAt\":\"2025-04-22\",\"summary\":\"Magic Portfolio's RouteGuard component takes care of conditionally rendering pages based on your settings.\",\"image\":\"/images/gallery/horizontal-2.jpg\",\"images\":[],\"tag\":\"Magic Portfolio\",\"team\":[],\"link\":\"\"},\"slug\":\"pages\",\"content\":\"$1a\"},\"thumbnail\":true,\"direction\":\"column\"}]]}]]}]\n11:[\"$\",\"$L1b\",null,{}]\n12:[\"$\",\"$L2\",null,{\"m\":{\"hide\":true},\"direction\":\"column\",\"maxWidth\":12,\"paddingLeft\":\"40\",\"fitHeight\":true,\"position\":\"sticky\",\"top\":\"80\",\"gap\":\"16\",\"children\":[\"$\",\"$L1c\",null,{\"fitHeight\":true}]}]\n13:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/3o62orymmkl42.js\",\"async\":true}]\n14:[\"$\",\"$L1d\",null,{\"children\":[\"$\",\"$1e\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1f\"}]}]\n1f:null\n","/blog/$d$slug":"1:\"$Sreact.fragment\"\n2:I[339756,[\"/_next/static/chunks/304whyotwl194.js\",\"/_next/static/chunks/0c934zwmw2ase.js\",\"/_next/static/chunks/2250m-j_-u-3r.js\",\"/_next/static/chunks/437et